# Copy to .env and fill in.

# scribe.json path that the forked userscript writes to (File System Access API handle target).
SCRIBE_PATH=data/scribe.json

# scribe-ai.json path that classify_to_scribe_ai.py writes (and userscript polls).
SCRIBE_AI_PATH=data/scribe-ai.json

# PROJECT_threads-to-note location. watch_pipeline.py runs `python app.py` here.
NOTE_PROJECT_PATH=..\PROJECT_threads-to-note

# Path to the chrome-ws CLI (bundled with superpowers-chrome plugin).
# Find it under: ~/.claude/plugins/cache/superpowers-marketplace/superpowers-chrome/<version>/skills/browsing/chrome-ws
CHROME_WS_PATH=

# (Optional) Path to threads-scriber.user.js source — only needed when running _rebuild_userscript.py.
THREADS_SCRIBER_PATH=..\threads-scriber\threads-scriber.user.js

# Gemini API key for classify_to_scribe_ai.py.
GEMINI_API_KEY=

# Gemini model used for classification.
CLASSIFIER_MODEL=gemini-2.5-flash

# Watcher tuning.
DEBOUNCE_SECONDS=2.0
POLL_SECONDS=1.0
