# Copy to .env and fill in.

# Non-secret paths live in config.json under "paths".

# ---------- LLM provider selection ----------
# One of: gemini | anthropic | openai
# Defaults to "gemini" if unset (also overridable in config.json under "llm.provider").
# API providers only — local agent CLIs are deliberately unsupported; see docs/decisions/ADR-001.
LLM_PROVIDER=gemini

# API key for the selected provider. Fill in only the one you use.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# (Optional) Override the default model identifiers per stage.
# If unset, defaults come from the provider:
#   gemini    -> gemini-2.5-flash (text + vision)
#   anthropic -> claude-sonnet-4-6 (text + vision)
#   openai    -> gpt-4o-mini (text), gpt-4o (vision)
# THREADS_LLM_CLASSIFIER_MODEL=
# THREADS_LLM_TITLE_MODEL=
# THREADS_LLM_OCR_MODEL=

# Legacy Gemini-specific overrides (still honored if set; prefer the THREADS_LLM_* vars above).
# CLASSIFIER_MODEL=gemini-2.5-flash
# IMAGE_OCR_MODEL=gemini-2.5-flash

# ---------- Image OCR ----------
# Toggle the OCR stage. Trigger categories live in config.json under image-ocr.
# Note: scripts/image_ocr_to_markdown.py CLI currently supports only --ocr-backend gemini;
# the multi-provider factory is wired into the main pipeline (workflow), not the standalone CLI.
IMAGE_OCR_ENABLED=true

# ---------- Thread context (ancestor chain + replies) ----------
# Capture the parent-post chain and visible replies when a saved item is a reply.
# Values here override the config.json "thread-context" block.
# THREADS_CONTEXT_ENABLED=true
# THREADS_CONTEXT_MIN_REPLY_CHARS=12
# THREADS_CONTEXT_MAX_REPLIES=30

# ---------- Chandra OCR (vLLM) ----------
# Used when config.json has image-ocr.backend=chandra and image-ocr.method=vllm.
# These public defaults come from https://github.com/datalab-to/chandra.
# Check that repo for the latest Chandra configuration.
MODEL_CHECKPOINT=datalab-to/chandra-ocr-2
MAX_OUTPUT_TOKENS=12384
VLLM_API_BASE=http://localhost:8000/v1
VLLM_MODEL_NAME=chandra
VLLM_GPUS=0

# ---------- Watcher tuning (watch_pipeline.py) ----------
DEBOUNCE_SECONDS=2.0
POLL_SECONDS=1.0
