{
  "paths": {
    "catch-json": "data/catch.json",
    "unsave-json": "data/unsave.json",
    "markdown-output-root": "D:/<output folder for the markdown files>"
  },
  "llm": {
    "provider": "gemini",
    "text-model": "gemini-2.5-flash",
    "title-model": "gemini-2.5-flash",
    "vision-model": "gemini-2.5-flash"
  },
  "categories": [
    "AI",
    "Tech",
    "Life Tips",
    "Food",
    "Travel",
    "Workplace",
    "Fitness",
    "Mental Health",
    "Entertainment",
    "History",
    "Politics"
  ],
  "unsaved-categories": ["AI", "Tech"],
  "category-overrides": [],
  "image-ocr": {
    "backend": "gemini",
    "trigger-categories": ["AI"]
  },
  "thread-context": {
    "enabled": true,
    "min-reply-chars": 12,
    "max-replies": 30
  },
  "hints": [
    "If content discusses AI agents, prompts, LLMs, or automation workflows, prefer AI over Tech.",
    "If content is clearly about a specific public figure or fandom topic, prefer the most specific matching category."
  ]
}
